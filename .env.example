# Opción 1: Connection Pooler (recomendado para Render/Vercel - usa IPv4)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Opción 2: Conexión directa (solo para desarrollo local - usa IPv6)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Opción 3: Variables separadas
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PASSWORD=[YOUR-PASSWORD]
